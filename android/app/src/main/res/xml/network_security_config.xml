<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- HTTP 서버(cleartext) 연결 허용 - API 서버가 HTTP 사용 시 필요 -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
